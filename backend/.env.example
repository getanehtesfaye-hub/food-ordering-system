# PostgreSQL — individual settings (local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=food_ordering

# Or use a single connection string (production / cloud)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/food_ordering

# Connection pool (optional)
# DB_POOL_MAX=20
# DB_POOL_IDLE_MS=30000
# DB_CONNECT_TIMEOUT_MS=5000

# SSL (set to true for managed PostgreSQL providers)
# DB_SSL=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# File Upload
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880
